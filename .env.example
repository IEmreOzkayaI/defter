# Canonical ve önizleme için kök URL (sonunda / olmadan)
# Örnek (Vercel): https://defter-nu.vercel.app
VITE_SITE_URL=

# «Nasıl başlanır» önizleme medyası — belirtilmezse /video.mp4 (public/video.mp4), sessiz otomatik oynar.
# Diğer örnekler: /videos/clip.webm  |  https://youtu.be/...  |  https://cdn.../tanitim.mp4
# VITE_LANDING_HERO_VIDEO=

# Backend base URL (defter-be). Üretimde mutlaka https://… tam adres; şema yoksa tarayıcı göreli URL üretir (405).
# Railway: API servisinin public domain’i (…up.railway.app). *.railway.internal tarayıcıdan çalışmaz.
# VITE_BACKEND_BASE_URL=http://localhost:3001

# Yerel `vite` sunucusu (varsayılan 3000)
# VITE_DEV_PORT=3000

# Docker Nginx CSP: bu sayfayı iframe içinde gösterecek üst origin(ler) (boş = 'none')
# IFRAME_ALLOWED_ORIGIN=https://parent.example.com

# Docker compose
# FRONTEND_PORT=3000

# Railway: PORT otomatik verilir; ekstra ayar gerekmez (entrypoint nginx'i buna bağlar).
